# ============================================================
#  CONFIG DU BRAIN — copie ce fichier en .env et remplis-le
#  (en local). Sur Railway, mets ces mêmes clés dans l'onglet
#  "Variables". Ne commit JAMAIS ton vrai .env (déjà dans .gitignore).
# ============================================================

# --- OBLIGATOIRE : le cœur du bot (il fait tourner Claude) ---
# Crée une clé sur https://console.anthropic.com (et ajoute des crédits).
ANTHROPIC_API_KEY=sk-ant-api03-REMPLACE-MOI

# --- Ton identité (persona) ---
# PERSONA_KEY = nom du fichier dans prompts/personas/ sans .md (laisse "me")
PERSONA_KEY=me
# Ton prénom (affiché côté modèle dans l'historique)
PERSONA_DISPLAY_NAME=TonPrenom

# --- Tes liens canoniques (mets ceux que tu utilises, laisse vide sinon) ---
CALENDLY_URL=https://calendly.com/ton-compte/ton-evenement
YOUTUBE_URL=
WEBSITE_URL=

# --- Réglages avancés (valeurs par défaut OK, ne change que si tu sais) ---
CLAUDE_MODEL=claude-sonnet-4-6
MAX_THINKING_TOKENS=8000
MAX_TURNS=15
